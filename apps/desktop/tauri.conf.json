{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Spren",
  "version": "0.3.0",
  "identifier": "ai.marsys.spren",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Spren",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
